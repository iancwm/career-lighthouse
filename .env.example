ANTHROPIC_API_KEY=sk-ant-...
ALLOWED_ORIGINS=http://localhost:3000
QDRANT_URL=http://qdrant:6333
DATA_PATH=/app/data/qdrant
SESSIONS_DIR=/app/data/sessions
CAREER_PROFILES_DIR=/app/knowledge/career_profiles
EMPLOYERS_DIR=/app/knowledge/employers
DRAFT_TRACKS_DIR=/app/knowledge/draft_tracks
CAREER_TRACKS_REGISTRY_PATH=/app/knowledge/career_tracks.yaml
CAREER_PROFILE_HISTORY_DIR=/app/knowledge/career_profiles_history
QUERY_LOG_PATH=/app/logs/query_log.jsonl
LLM_TRACE_LOG_PATH=/app/logs/llm_trace_log.jsonl
TRACK_PUBLISH_JOURNAL_PATH=/app/logs/track_publish_journal.jsonl
TRACK_PUBLISH_LOG_PATH=/app/logs/track_publish_log.jsonl
TRACKS_VERSION_PATH=/app/knowledge/.tracks-version
SENTENCE_TRANSFORMERS_HOME=/app/.cache
UV_CACHE_DIR=/home/appuser/.cache/uv
# Admin key for /admin UI and /api/kb/* + /api/sessions/* endpoints.
# Leave empty to disable auth in development. Must be set in production.
ADMIN_KEY=
